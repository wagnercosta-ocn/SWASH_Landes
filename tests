import numpy as np
import pandas as pd
import os
import glob
from math import radians, sin, cos
from datetime import datetime

# =========================
# USER INPUTS
# =========================
csv_file = "/scratch/work/langercostaw/swash_landes/transects_processed/transects_processed.csv"
aut_folder = "/scratch/work/langercostaw/swash_landes/swash_cases/AUT"
output_root = "swash_runs"

# --- DATE FILTER ---
start_date = "202501250000"
end_date = "202501312359"

start_dt = datetime.strptime(start_date, "%Y%m%d%H%M")
end_dt = datetime.strptime(end_date, "%Y%m%d%H%M")

os.makedirs(output_root, exist_ok=True)

# =========================
# HAVERSINE
# =========================
def haversine(lat1, lon1, lat2, lon2):
    R = 6371000

    dlat = radians(lat2 - lat1)
    dlon = radians(lon2 - lon1)

    a = (
        sin(dlat / 2) ** 2
        + cos(radians(lat1))
        * cos(radians(lat2))
        * sin(dlon / 2) ** 2
    )

    return 2 * R * np.arcsin(np.sqrt(a))

# =========================
# LOAD TRANSECTS
# =========================
df = pd.read_csv(csv_file)

transects = {}

for tid, g in df.groupby("transect_id"):

    g = g.sort_values("extension")

    offshore = g.iloc[-1]

    transects[tid] = {
        "lat": offshore["lat"],
        "lon": offshore["lon"],
        "angle": g["orientation_deg"].iloc[0],
        "depths": g["smooth_depth"].values[::-1] * -1,
        "x": g["extension"].values[::-1]
    }

    transects[tid]["x"] -= transects[tid]["x"].min()

# =========================
# READ AUT FILE
# =========================
def read_aut_file(file):

    blocks = []

    with open(file) as f:
        lines = f.readlines()

    i = 0

    while i < len(lines):

        parts = lines[i].split()

        if len(parts) == 7:

            lon, lat = float(parts[0]), float(parts[1])

            date = parts[2]

            nf = int(float(parts[3]))
            nd = int(float(parts[4]))

            d0 = float(parts[5])
            f0 = float(parts[6])

            i += 1

            data = []

            for _ in range(nd):

                row = []

                while len(row) < nf:
                    row.extend([float(x) for x in lines[i].split()])
                    i += 1

                data.append(row[:nf])

            blocks.append({
                "lat": lat,
                "lon": lon,
                "date": date,
                "nf": nf,
                "nd": nd,
                "f0": f0,
                "d0": d0,
                "spec": np.array(data)
            })

        else:
            i += 1

    return blocks

# =========================
# SPECTRUM QUALITY
# =========================
def check_spectrum_quality(freqs, Sf):

    df = np.diff(freqs)
    df = np.append(df, df[-1])

    m0 = np.sum(Sf * df)

    Hs = 4 * np.sqrt(m0) if m0 > 0 else 0

    fp = freqs[np.argmax(Sf)] if np.max(Sf) > 0 else 0
    Tp = 1 / fp if fp > 0 else 0

    flags = []

    if Hs < 0.05 or Hs > 20:
        flags.append(f"Hs={Hs:.2f}")

    if Tp < 2 or Tp > 25:
        flags.append(f"Tp={Tp:.2f}")

    return len(flags) == 0, Hs, Tp, flags

# =========================
# WRITE SPECTRUM
# =========================
def write_spectrum(folder, tid, block):

    nf = block["nf"]
    f0 = block["f0"]

    freqs = np.array([f0 * (1.1 ** i) for i in range(nf)])

    spec = block["spec"]

    # integrate over directions
    Sf = np.sum(spec, axis=0)

    ok, Hs, Tp, flags = check_spectrum_quality(freqs, Sf)

    if not ok:
        print(f"⚠️ BAD → {tid} {block['date']} {flags}")
    else:
        print(f"OK → {tid} {block['date']} Hs={Hs:.2f} Tp={Tp:.1f}")

    fname = f"{tid}_{block['date']}.sp1d"

    path = os.path.join(folder, fname)

    with open(path, "w") as f:

        f.write("SPEC1D\n")

        for fr, s in zip(freqs, Sf):
            f.write(f"{fr:.5f} {s:.6e}\n")

    return fname

# =========================
# WRITE SWS
# =========================
def write_sws(folder, tid, data, spec_file, block):

    x = data["x"]

    dx = abs(np.mean(np.diff(x)))

    mxc = len(x)

    xlen = mxc * dx

    alfa = 270 - data["angle"]

    date = block["date"]

    sws_filename = f"{tid}_{date}.sws"

    path = os.path.join(folder, sws_filename)

    with open(path, "w") as f:

        f.write(f"PROJ 'Landes+Pays-Basque' 'Transect {tid}'\n")

        f.write("SET 0 90 0.0 200 2 NAUTICAL\n\n")

        f.write("MODE DYN ONED\n\n")

        f.write(
            f"CGRID REG 0 0 {alfa:.2f} "
            f"{xlen:.2f} 0 {mxc-1} 0\n"
        )

        f.write("VERT 1\n")

        f.write(
            f"INPGRID BOTTOM 0 0 {alfa:.2f} "
            f"{mxc-1} 0 {abs(dx):.3f} 0\n"
        )

        f.write(f"READINP BOTTOM 1 '{tid}.bot' 1 0 FREE\n\n")

        f.write("INIT ZERO\n\n")

        f.write(
            f"BOU SIDE W CCW BTYPE WEAK CON "
            f"SPECFILE '{spec_file}'\n\n"
        )

        f.write("BOU SIDE E CCW BTYPE RADIATION\n\n")

        f.write("FRIC MANNING 0.019\n")

        f.write("TIMEI METH EXPL 0.2 0.5\n")

        f.write("BREAK\n")

        f.write("NONHYDROSTATIC\n")

        f.write("QUANT HS SETUP HRUN DUR 40 MIN\n")

        f.write(
            f"FRAME 'GRID' 0 0 {alfa:.2f} "
            f"{xlen:.2f} 0 {mxc-1} 0\n"
        )

        f.write(
            f"BLOCK 'GRID' NOHEAD "
            f"'output_{tid}_{date}.mat' "
            f"LAY 3 XP DEPTH BOTL WATLEV "
            f"HRUN BRKP SETUP HSIG HRMS\n"
        )

        f.write("TEST 1,0\n")

        f.write("COMPUTE 000000.000 0.001 SEC 7200\n")

        f.write("STOP\n")

    return sws_filename

# =========================
# WRITE SWASHINIT
# =========================
def write_swashinit(folder, sws_filename):

    path = os.path.join(folder, "swashinit")

    with open(path, "w") as f:

        f.write("    6                                   version of initialisation file\n")

        f.write("Meteo France                            name of institute\n")

        f.write("    3                                   command file ref. number\n")

        f.write(f"{sws_filename}\n")

        f.write("    4                                   print file ref. number\n")

        f.write("PRINT                                   print file name\n")

        f.write("    4                                   test file ref. number\n")

        f.write("\n")

        f.write("    6                                   screen ref. number\n")

        f.write("99999                                   highest file ref. number\n")

        f.write("$                                       comment identifier\n")

        f.write("                                               TAB character\n")

        f.write("\\                                       dir sep char in input file\n")

        f.write("/                                       dir sep char replacing previous one\n")

        f.write("    7                                   default time coding option\n")

        f.write("    1                                   grid partitioning option\n")

        f.write("    1                                   option to merge output files\n")

# =========================
# MAIN LOOP
# =========================
aut_files = glob.glob(os.path.join(aut_folder, "AUT*"))

processed = set()

for aut in aut_files:

    print(f"\nProcessing {aut}")

    blocks = read_aut_file(aut)

    for block in blocks:

        dt = datetime.strptime(block["date"], "%Y%m%d%H%M")

        if not (start_dt <= dt <= end_dt):
            continue

        for tid, data in transects.items():

            key = (tid, block["date"])

            if key in processed:
                continue

            dist = haversine(
                data["lat"],
                data["lon"],
                block["lat"],
                block["lon"]
            )

            # skip if too far
            if dist > 50000:
                continue

            transect_folder = os.path.join(
                output_root,
                str(tid)
            )

            case_folder = os.path.join(
                transect_folder,
                f"case_{block['date']}"
            )

            os.makedirs(case_folder, exist_ok=True)

            # =========================
            # BOT FILE
            # =========================
            bot_path = os.path.join(
                case_folder,
                f"{tid}.bot"
            )

            np.savetxt(
                bot_path,
                data["depths"],
                fmt="%.5f"
            )

            # =========================
            # SPECTRUM FILE
            # =========================
            spec_file = write_spectrum(
                case_folder,
                tid,
                block
            )

            # =========================
            # SWS FILE
            # =========================
            sws_filename = write_sws(
                case_folder,
                tid,
                data,
                spec_file,
                block
            )

            # =========================
            # SWASHINIT FILE
            # =========================
            write_swashinit(
                case_folder,
                sws_filename
            )

            processed.add(key)

print("\n✅ Pipeline completed.")
